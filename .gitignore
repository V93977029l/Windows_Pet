# godot-cpp - ignore source but keep compiled libs
gdextension/godot-cpp/*
!gdextension/godot-cpp/bin
gdextension/godot-cpp/bin/*
!gdextension/godot-cpp/bin/*.lib
!gdextension/godot-cpp/bin/*.a

# Build intermediate files (excluding useful binaries)
.sconsign.dblite
*.o
*.obj
*.bc
*.exp
*.pdb

# Exclude lib files except in godot-cpp/bin
*/*.lib
!gdextension/godot-cpp/bin/*.lib

# Build cache
.sconf_temp
.scons_node_count
.cache/
scons_cache/

# IDE
.vscode/
.idea/
*.code-workspace

# Python
__pycache__/
*.pyc
.venv/
venv/

# Misc
*.log
logs/
cache/

.godot/